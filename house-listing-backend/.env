# Production Environment Variables
NODE_ENV=production
PORT=5000

# MongoDB URI (Replace with MongoDB Atlas connection string in production)
MONGO_URI=mongodb://127.0.0.1:27017/house-listing

# JWT Secrets (Use strong random strings in production)
JWT_SECRET=supersecretjwtkeythatissufficientlylong_access
JWT_REFRESH_SECRET=supersecretjwtkeythatissufficientlylong_refresh
JWT_EXPIRE=15m

# Cloudinary Setup for Image Uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS
CORS_ORIGIN=https://your-frontend-domain.vercel.app
